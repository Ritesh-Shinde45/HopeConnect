<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB"
    android:fitsSystemWindows="true">

    <!-- Status Bar Spacer -->
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#F8F9FB"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Profile Image -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profileImage"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_person"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusBarSpacer"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <!-- Hi, Username -->
    <TextView
        android:id="@+id/userName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Hi, User"
        android:textColor="#808080"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/profileImage"
        app:layout_constraintTop_toTopOf="@id/profileImage" />

    <!-- App label -->
    <TextView
        android:id="@+id/location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HopeConnect"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/userName"
        app:layout_constraintTop_toBottomOf="@id/userName" />

    <!-- Notification Bell -->
    <ImageButton
        android:id="@+id/btnNotification"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_notification"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="@id/profileImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/profileImage" />

    <!-- Scrollable main content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/profileImage"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search Bar -->
            <EditText
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/search_bg"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="10dp"
                android:hint="Search for missing/found person details"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColorHint="#999999" />

            <!-- Promo Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/promoCard"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/promo_card_gradient"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/promoText"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:text="Technology with Humanity"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:lineHeight="26dp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnReadMore"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_below="@id/promoText"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Read more"
                        android:textAllCaps="false"
                        android:textColor="#3F51B5"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_launcher_about"
                        android:scaleType="centerInside" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Cases Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/txtRecentCases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Cases"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#3F51B5"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Filter Buttons -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAllCases"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#E3F2FD"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="All Cases"
                        android:textAllCaps="false"
                        android:textColor="#2196F3"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_all_cases"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#FF6B35"
                        app:strokeColor="#00000000"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMissing"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="Missing"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_missing"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#666666"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFound"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="Found"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_found"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#666666"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChildren"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="Children"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_children"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#666666"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdults"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="Adults"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_adults"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#666666"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnElderly"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="14dp"
                        android:paddingEnd="18dp"
                        android:text="Elderly"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_elderly"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp"
                        app:iconTint="#666666"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Cases Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/txtMissingCases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Missing Cases"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSeeAllCases"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#3F51B5"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/homeProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!--
                Horizontal RecyclerView for case cards.
                The adapter (ReportAdapter) inflates item_case_card.xml for each item.
                Each card is fixed width set inside the adapter via its LayoutParams.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/casesRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:elevation="12dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/nav_item_color_state"
        app:itemTextColor="@color/nav_item_color_state"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>