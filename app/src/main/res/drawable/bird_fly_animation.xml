<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bird_fly_animation.xml -->
<!-- Animated vector drawable: bird flapping wings -->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="80dp"
            android:height="80dp"
            android:viewportWidth="100"
            android:viewportHeight="100">

            <!-- Bird body -->
            <path
                android:name="body"
                android:fillColor="#4A90D9"
                android:pathData="M50,55 C45,52 38,50 35,48 C32,46 33,42 37,43 C41,44 46,47 50,50 C54,47 59,44 63,43 C67,42 68,46 65,48 C62,50 55,52 50,55 Z" />

            <!-- Left wing -->
            <path
                android:name="left_wing"
                android:fillColor="#FF6B35"
                android:pathData="M50,50 C44,45 35,38 28,35 C22,32 20,37 25,40 C30,43 40,47 50,50 Z" />

            <!-- Right wing -->
            <path
                android:name="right_wing"
                android:fillColor="#FF6B35"
                android:pathData="M50,50 C56,45 65,38 72,35 C78,32 80,37 75,40 C70,43 60,47 50,50 Z" />

            <!-- Bird head -->
            <path
                android:name="head"
                android:fillColor="#4A90D9"
                android:pathData="M50,42 C53,42 56,39 56,36 C56,33 53,30 50,30 C47,30 44,33 44,36 C44,39 47,42 50,42 Z" />

            <!-- Beak -->
            <path
                android:name="beak"
                android:fillColor="#FFB347"
                android:pathData="M56,35 L62,37 L56,39 Z" />

            <!-- Eye -->
            <path
                android:name="eye"
                android:fillColor="#FFFFFF"
                android:pathData="M52,34 C53,34 54,35 54,36 C54,37 53,38 52,38 C51,38 50,37 50,36 C50,35 51,34 52,34 Z" />

            <path
                android:name="pupil"
                android:fillColor="#1A1A2E"
                android:pathData="M52.5,35.5 C53,35.5 53.5,36 53.5,36.5 C53.5,37 53,37.5 52.5,37.5 C52,37.5 51.5,37 51.5,36.5 C51.5,36 52,35.5 52.5,35.5 Z" />

            <!-- Tail feathers -->
            <path
                android:name="tail"
                android:fillColor="#2E6DB4"
                android:pathData="M50,55 C48,60 44,65 40,68 C44,65 50,62 50,58 C50,62 56,65 60,68 C56,65 52,60 50,55 Z" />

        </vector>
    </aapt:attr>

    <!-- Left wing flap animation -->
    <target android:name="left_wing">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:duration="300"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"
                android:valueFrom="M50,50 C44,45 35,38 28,35 C22,32 20,37 25,40 C30,43 40,47 50,50 Z"
                android:valueTo="M50,50 C44,55 35,62 28,65 C22,68 20,63 25,60 C30,57 40,53 50,50 Z"
                android:valueType="pathType" />
        </aapt:attr>
    </target>

    <!-- Right wing flap animation -->
    <target android:name="right_wing">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:duration="300"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate"
                android:valueFrom="M50,50 C56,45 65,38 72,35 C78,32 80,37 75,40 C70,43 60,47 50,50 Z"
                android:valueTo="M50,50 C56,55 65,62 72,65 C78,68 80,63 75,60 C70,57 60,53 50,50 Z"
                android:valueType="pathType" />
        </aapt:attr>
    </target>

</animated-vector>