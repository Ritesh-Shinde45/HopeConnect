<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_tertiary">
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#F8F9FB"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- Filter card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/bg_primary">

        <!-- Days input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show cases from last"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/et_days_filter"
                android:layout_width="64dp"
                android:layout_height="40dp"
                android:text="7"
                android:inputType="number"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_field"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="days"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_apply_date_filter"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Filter"
                android:textSize="12sp"
                android:backgroundTint="@color/brand_primary" />
        </LinearLayout>

        <!-- Quick select chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_7d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 days"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_30d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 days"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_90d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90 days"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
        </LinearLayout>
    </LinearLayout>

    <!-- Result label -->
    <TextView
        android:id="@+id/tv_date_result_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Showing cases from last 7 days"
        android:textSize="12sp"
        android:textColor="@color/text_tertiary" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No cases found"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try increasing the number of days"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history_reports"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />
    <ProgressBar
        android:id="@+id/progressBarDate"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>