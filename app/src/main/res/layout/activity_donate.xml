<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

 <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#4A4E9D"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4A4E9D"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Buy Tea ☕"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Support the Developer"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Amount Buttons Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:weightSum="3">

                    <Button
                        android:id="@+id/btn10"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="₹10"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#00E5FF"/>

                    <Button
                        android:id="@+id/btn20"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="₹20"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#0F9D58"/>

                    <Button
                        android:id="@+id/btn50"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="₹50"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#FFCA28"/>
                </LinearLayout>

                <!-- Amount Buttons Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <Button
                        android:id="@+id/btn100"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="₹100"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#F57C00"/>

                    <Button
                        android:id="@+id/btn1000"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="₹1000"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#E91E63"/>

                    <Button
                        android:id="@+id/btnCustom"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Custom"
                        android:textSize="12sp"
                        android:layout_margin="4dp"
                        android:backgroundTint="#E62117"/>
                </LinearLayout>

                <!-- Custom Amount Field (hidden until Custom tapped) -->
                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Amount"
                    android:inputType="numberDecimal"
                    android:visibility="gone"
                    android:layout_marginTop="12dp"/>

                <!-- Short Note Field: appears first (because the amount fields are GONE) -->
                <EditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="Write a short note (optional)"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="16dp"/>

                <!-- Buy Button -->
                <Button
                    android:id="@+id/btnPay"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="Buy Tea"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#4A4E9D"
                    android:layout_marginTop="20dp"/>

                <!-- QR Image (hidden until generated) -->
                <ImageView
                    android:id="@+id/imgQR"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center_horizontal"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"/>

                <!-- UPI ID (displayed below QR for convenience) -->
                <TextView
                    android:id="@+id/tvUpiId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8080769308@axl"
                    android:textSize="16sp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"/>

                <!-- Copy UPI ID Button -->
                <Button
                    android:id="@+id/btnCopy"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="Copy UPI ID"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#4A4E9D"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>