<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_tertiary">
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/bg_primary">

        <ImageButton
            android:id="@+id/btn_back_announcement"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Announcements"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress + status -->
            <ProgressBar
                android:id="@+id/progress_export"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_export_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/status_success"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <!-- Send form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Announcement"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Title"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_announcement_title"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Announcement title"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="text"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audience"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinner_audience"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_announcement_message"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Write your announcement..."
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btn_send_announcement"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Send Notification"
                    android:backgroundTint="@color/status_success"/>
            </LinearLayout>

            <!-- Sent announcements card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sent Announcements"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_no_announcements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No announcements sent yet"
                    android:gravity="center"
                    android:padding="16dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_tertiary"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sent_announcements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>