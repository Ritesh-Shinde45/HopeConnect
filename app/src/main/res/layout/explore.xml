<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/explore_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- ====================== SCROLLABLE CONTENT ====================== -->
    <!-- Give a bottom margin equal to BottomNavigationView height so content doesn't go under it -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:layout_marginBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/containerLinear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">



            <!-- ====================== TOP WHITE AREA ====================== -->
            <LinearLayout
                android:id="@+id/topWhite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:paddingTop="24dp"
                android:paddingBottom="12dp"
                android:fitsSystemWindows="true">

                <!-- Search Bar with Profile Picture -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F1F3F6">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_search"
                                android:tint="#888888"
                                tools:ignore="UseAppTint" />

                            <EditText
                                android:id="@+id/searchEditText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:background="@null"
                                android:hint="Looking for"
                                android:textColorHint="#888888"
                                android:textColor="#222222"
                                android:textSize="14sp"
                                android:inputType="text"
                                android:maxLines="1" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/profileImage"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="2dp"
                        app:civ_border_color="#DDDDDD" />

                </LinearLayout>

                <!-- Category Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="#222222"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4"
                        android:gravity="center">

                        <!-- Missed Reports -->
                        <LinearLayout
                            android:id="@+id/categoryMissedReports"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardMissed"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#FFA726">

                                <ImageView
                                    android:id="@+id/iconMissed"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_misseed_reports"
                                    app:tint="#FFFFFF" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/labelMissed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Missed Reports"
                                android:textColor="#444444"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>

                        <!-- Match Face -->
                        <LinearLayout
                            android:id="@+id/categoryMatchFace"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardMatch"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F1F3F6">

                                <ImageView
                                    android:id="@+id/iconMatch"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_face_match"
                                    app:tint="#AAAAAA" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/labelMatch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Match Face"
                                android:textColor="#444444"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>

                        <!-- Your Helps -->
                        <LinearLayout
                            android:id="@+id/categoryYourHelps"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardHelp"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F1F3F6">

                                <ImageView
                                    android:id="@+id/iconHelp"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_your_helps"
                                    app:tint="#AAAAAA" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/labelHelp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Helps"
                                android:textColor="#444444"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>

                        <!-- Achievements -->
                        <LinearLayout
                            android:id="@+id/categoryAchivements"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardAchieve"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F1F3F6">

                                <ImageView
                                    android:id="@+id/iconAchieve"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_achievements"
                                    app:tint="#AAAAAA" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/labelAchieve"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Achievements"
                                android:textColor="#444444"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Best Destination Title + Filter Button -->

                <!-- ====================== BOTTOM COLORED AREA (fragment container) ====================== -->
                <LinearLayout
                    android:id="@+id/bottomColoredArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/gradient_background"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <FrameLayout
                        android:id="@+id/fragmentContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:elevation="12dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/nav_item_color_state"
        app:itemTextColor="@color/nav_item_color_state"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>